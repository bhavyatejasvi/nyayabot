TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# ─── Groq (free — no credit card needed) ────────────────────────────────────
# Sign up: https://console.groq.com → API Keys → Create key
# Used for: Whisper voice transcription (whisper-large-v3-turbo)
GROQ_API_KEY=gsk_...

# ─── Google Gemini / AI Studio (free — no credit card needed) ───────────────
# Sign up: https://aistudio.google.com → Get API Key
# Free tier: 15 requests/min, 1 million tokens/day
# Used for: intent classification + legal document generation
GOOGLE_AI_API_KEY=AIza...

# ─── Supabase (free tier — 500 MB DB + 1 GB storage) ───────────────────────
# Sign up: https://supabase.com → New Project
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ─── App ─────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
BASE_URL=http://localhost:3000
