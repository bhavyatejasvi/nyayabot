# ─── Twilio (WhatsApp sandbox — free) ───────────────────────────────────────
# Sign up: https://console.twilio.com → Messaging → Try WhatsApp
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_NUMBER=whatsapp:+your_twilio_sandbox_number

# ─── Groq (free — no credit card needed) ────────────────────────────────────
# Sign up: https://console.groq.com → API Keys → Create key
# Used for: voice transcription (Whisper) + AI legal reasoning (LLaMA 3.3 70B)
GROQ_API_KEY=your_groq_api_key

# ─── Google Maps (for nearest office lookup) ─────────────────────────────────
# Sign up: https://console.cloud.google.com → Enable Places API
GOOGLE_AI_API_KEY=your_google_maps_api_key

# ─── Supabase (optional — free tier: 500 MB DB + 1 GB storage) ──────────────
# Sign up: https://supabase.com → New Project
# Leave as-is to use in-memory sessions for local dev
SUPABASE_URL=your_supabase_project_url
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ─── App ─────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
BASE_URL=http://localhost:3000
